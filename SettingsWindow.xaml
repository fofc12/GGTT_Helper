<Window x:Class="ZeroWubiLens.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置 · 零西五笔工坊" Width="520" Height="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">
    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,14">

                <!-- 快捷键 -->
                <TextBlock Text="快捷键" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <WrapPanel Margin="0,0,0,4">
                    <CheckBox x:Name="ChkAlt"   Content="Alt"   Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkCtrl"  Content="Ctrl"  Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkShift" Content="Shift" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkWin"   Content="Win"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="键位:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CboKey" Width="72"/>
                </StackPanel>

                <!-- 网页与代理 -->
                <TextBlock Text="网页与代理" FontSize="14" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <CheckBox x:Name="ChkWebEnabled" Content="加载拆字图"/>
                <WrapPanel Margin="0,4,0,4">
                    <TextBlock Text="缩放:" VerticalAlignment="Center" Margin="0,0,6,0" Width="50"/>
                    <ComboBox x:Name="CboZoom" Width="72">
                        <ComboBoxItem>0.7</ComboBoxItem><ComboBoxItem>0.8</ComboBoxItem>
                        <ComboBoxItem>0.9</ComboBoxItem><ComboBoxItem>1.0</ComboBoxItem>
                        <ComboBoxItem>1.1</ComboBoxItem><ComboBoxItem>1.2</ComboBoxItem>
                    </ComboBox>
                </WrapPanel>
                <CheckBox x:Name="ChkHideChrome" Content="隐藏网页栏目·表格（仅保留拆图）"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="代理:" VerticalAlignment="Center" Margin="0,0,6,0" Width="50"/>
                    <TextBox x:Name="TxtProxy" Width="210" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Text=" 留空=直连" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 取字与窗口 -->
                <TextBlock Text="取字与窗口" FontSize="14" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <CheckBox x:Name="ChkClipFallback" Content="启用剪贴板回退（部分软件才需要）"/>
                <UniformGrid Columns="4" Rows="3" Margin="0,6,0,0">
                    <TextBlock Text="紧凑宽" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtCompactW" Width="54" TextAlignment="Center"/>
                    <TextBlock Text="紧凑高" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtCompactH" Width="54" TextAlignment="Center"/>
                    <TextBlock Text="展开宽" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtExpandW" Width="54" TextAlignment="Center"/>
                    <TextBlock Text="展开高" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtExpandH" Width="54" TextAlignment="Center"/>
                    <TextBlock Text="下偏移px" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtOffset" Width="54" TextAlignment="Center"/>
                    <TextBlock Text="" VerticalAlignment="Center"/>
                    <TextBlock Text="" VerticalAlignment="Center"/>
                </UniformGrid>

                <!-- 词库 -->
                <TextBlock Text="词库" FontSize="14" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="路径:" VerticalAlignment="Center" Margin="0,0,6,0" Width="50"/>
                    <TextBox x:Name="TxtDictPath" Width="340" FontFamily="Consolas" FontSize="12" IsReadOnly="True"/>
                    <Button Content="…" Width="28" Height="24" Margin="6,0,0,0" FontSize="14" Padding="2,0" Click="BrowseDict"/>
                </StackPanel>

                <TextBlock Text="零西仓库" FontSize="14" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="路径:" VerticalAlignment="Center" Margin="0,0,6,0" Width="50"/>
                    <TextBox x:Name="TxtRepoPath" Width="340" FontFamily="Consolas" FontSize="12"/>
                    <Button Content="…" Width="28" Height="24" Margin="6,0,0,0" FontSize="14" Padding="2,0" Click="BrowseRepo"/>
                </StackPanel>

                <!-- 按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="保存并退出" Width="100" Height="28" Click="Save_Click"
                            Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                    <Button Content="取消" Width="60" Height="28" Margin="12,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
                <TextBlock Text="* 部分设置需重启程序生效" Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
