<Window x:Class="ZeroWubiLens.VocabularyWorkshopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="词库工坊 · 零西五笔" Width="1020" Height="690"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Background="#FFF5F7FA">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="安装并部署到 Rime" Width="130" Height="30" Margin="8,0,0,0" Click="Deploy_Click"/>
            <Button DockPanel.Dock="Right" Content="刷新" Width="68" Height="30" Margin="8,0,0,0" Click="Refresh_Click"/>
            <Button DockPanel.Dock="Right" Content="查询" Width="68" Height="30" Margin="8,0,0,0" Click="Lookup_Click"/>
            <TextBox x:Name="QueryBox" Height="30" FontSize="14" VerticalContentAlignment="Center"
                     ToolTip="输入词语或编码，例如 给力 / xwlt" KeyDown="QueryBox_KeyDown"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="CandidateGrid" Grid.Column="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="CandidateGrid_SelectionChanged"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="80"/>
                    <DataGridTextColumn Header="词语" Binding="{Binding Text}" Width="120"/>
                    <DataGridTextColumn Header="排序状态" Binding="{Binding DisplayState}" Width="92"/>
                    <DataGridTextColumn Header="词库来源" Binding="{Binding DisplayLevel}" Width="112"/>
                    <DataGridTextColumn Header="权重" Binding="{Binding Weight}" Width="80"/>
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Margin="12,0,0,0" Padding="12" Background="White" BorderBrush="#FFD7DEE8" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="编辑所选词条" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="词语"/>
                    <TextBox x:Name="EditTextBox" Height="28" Margin="0,3,0,8"/>
                    <TextBlock Text="编码"/>
                    <TextBox x:Name="EditCodeBox" Height="28" Margin="0,3,0,8" FontFamily="Consolas"/>
                    <TextBlock Text="加入词库"/>
                    <ComboBox x:Name="LevelBox" Height="28" Margin="0,3,0,8">
                        <ComboBoxItem Tag="modern" Content="L1 现代通用"/>
                        <ComboBoxItem Tag="focus" Content="L2 关注领域"/>
                        <ComboBoxItem Tag="personal" Content="L3 个人词库"/>
                    </ComboBox>
                    <TextBlock Text="权重"/>
                    <TextBox x:Name="WeightBox" Height="28" Text="100000" Margin="0,3,0,10" FontFamily="Consolas"/>

                    <UniformGrid Columns="2" Rows="4" Margin="0,2,0,8">
                        <Button Content="置顶" Margin="0,0,6,6" Click="Pin_Click"/>
                        <Button Content="确认首位" Margin="0,0,0,6" Click="Promote_Click"/>
                        <Button Content="候选4" Margin="0,0,6,6" Click="Pending_Click"/>
                        <Button Content="屏蔽" Margin="0,0,0,6" Click="Reject_Click"/>
                        <Button Content="清排序" Margin="0,0,6,6" Click="ClearState_Click"/>
                        <Button Content="加入词库" Margin="0,0,0,6" Click="AddEntry_Click"/>
                    </UniformGrid>

                    <TextBlock Text="规则：词库来源决定写入哪一层；置顶、确认首位、候选4、屏蔽是全局排序状态。部署后才进入 Rime。" TextWrapping="Wrap" Foreground="#FF667085" Margin="0,4,0,0"/>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <TextBox x:Name="LogBox" Grid.Row="2" Margin="0,10,0,0"
                 IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas"
                 Background="#FF111827" Foreground="#FFE5E7EB"/>
    </Grid>
</Window>
